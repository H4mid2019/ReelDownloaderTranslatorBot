# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
LOG_LEVEL=INFO # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Groq API Key (for Whisper transcription + LLM translation)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google AI Studio API Key (used by the /dl command — transcription + translation)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google AI model to use for /dl (transcription + translation, configurable)
# Default: gemini-2.5-flash-lite
# GOOGLE_AI_MODEL=gemini-2.5-flash-lite

# Local AI Fallback flag — set to True to enable the /dl command
USE_LOCAL_AI=False

# Truth Social Monitor
# Chat ID of the Telegram group to send alerts to
TRUTH_ALERT_CHAT_ID=your_chat_id_here
# Optional: Override the RSS feed URL (defaults to https://trumpstruth.org/feed)
# TRUTH_RSS_URL=https://trumpstruth.org/feed

# Instagram Authentication (choose ONE method below, METHOD 3 is recommended)

# METHOD 1 — Session ID (easiest for headless servers, expires ~every 10 hours)
# 1. Open instagram.com in Chrome and log in
# 2. Press F12 → Application tab → Cookies → https://www.instagram.com
# 3. Find the "sessionid" row — copy its Value
# 4. Paste below
# INSTAGRAM_SESSION_ID=your_session_id_here

# METHOD 2 — Full cookies file (more stable than session ID alone)
# 1. Login to Instagram in Chrome
# 2. Install "EditThisCookie" extension
# 3. Export cookies in Netscape format
# 4. Save file and set path below
# INSTAGRAM_COOKIES_FILE=instagram_cookies.txt

# METHOD 3 — Multiple full cookie files for rotation (RECOMMENDED for headless servers)
# Export a full Netscape cookie file from each browser/profile (Chrome, Firefox, Edge).
# Upload all files to the server. The bot auto-rotates when one expires.
# This is the most stable approach — full cookie files last much longer than session IDs.
# INSTAGRAM_COOKIES_FILES=cookies1.txt,cookies2.txt,cookies3.txt

# METHOD 4 — Multiple session IDs for rotation (lightweight alternative to METHOD 3)
# When one session ID expires, the bot automatically tries the next one.
# Use /setcookie in Telegram to add a fresh ID without SSH or restart.
# INSTAGRAM_SESSION_IDS=id1,id2,id3

# METHOD 4 — Auto-extract cookies from browser (desktop machines only)
# ONLY works if the bot runs on a machine with a GUI browser installed and logged in.
# NOT suitable for headless servers (Ubuntu ARM, Oracle Cloud, VPS, etc.).
# Values: chrome, firefox, edge, safari, chromium, brave
# INSTAGRAM_COOKIES_FROM_BROWSER=chrome

# Legacy credentials — DO NOT USE (broken in current yt-dlp Instagram extractor)
# INSTAGRAM_USERNAME=your_instagram_username

# Admin chat ID for system alerts (expired cookie warnings, /setcookie command).
# Defaults to TRUTH_ALERT_CHAT_ID if not set. Get your ID via /chatid in the bot.
# ADMIN_CHAT_ID=your_admin_chat_id_here

# AI Result Cache — avoids redundant Groq/Gemini API calls for repeated posts
# Transcripts and translations are stored in a local SQLite file.
# Default: enabled. Set to false to disable.
# ENABLE_AI_CACHE=true

# How many days to keep cached results before expiry (default: 30 days)
# CACHE_TTL_DAYS=30

# Path to the SQLite cache file (default: ./ai_cache.db next to bot.py)
# CACHE_DB_PATH=./ai_cache.db
