# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Groq API Key (for Whisper transcription + LLM translation)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Instagram Cookies (RECOMMENDED for downloading posts)
# Get cookies from Chrome browser:
# 1. Login to Instagram in Chrome
# 2. Install "EditThisCookie" extension
# 3. Export cookies in Netscape format
# 4. Save file and set path below
INSTAGRAM_COOKIES_FILE=instagram_cookies.txt

# Instagram Credentials (LEGACY - use cookies above instead)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# Model Configuration (OPTIONAL - defaults shown below)
# Transcription model: whisper-large-v3, whisper-large-v3-turbo, whisper-1
TRANSCRIPTION_MODEL=whisper-large-v3

# Translation/LLM model: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
TRANSLATION_MODEL=llama-3.3-70b-versatile
