# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Groq API Key (for Whisper transcription + LLM translation)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Instagram Authentication (choose ONE method below)

# METHOD 1 — Session ID (EASIEST for headless servers)
# 1. Open instagram.com in Chrome and log in
# 2. Press F12 → Application tab → Cookies → https://www.instagram.com
# 3. Find the "sessionid" row — copy its Value
# 4. Paste below
INSTAGRAM_SESSION_ID=your_session_id_here

# METHOD 2 — Full cookies file (MOST RELIABLE, survives session changes)
# 1. Login to Instagram in Chrome
# 2. Install "EditThisCookie" extension
# 3. Export cookies in Netscape format
# 4. Save file and set path below
# INSTAGRAM_COOKIES_FILE=instagram_cookies.txt

# Legacy credentials — DO NOT USE (broken in current yt-dlp Instagram extractor)
# INSTAGRAM_USERNAME=your_instagram_username
# INSTAGRAM_PASSWORD=your_instagram_password

