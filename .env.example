# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
LOG_LEVEL=INFO # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Groq API Key (for Whisper transcription + LLM translation)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google AI Studio API Key (used by the /dl command — transcription + translation)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google AI model to use for /dl (transcription + translation, configurable)
# Default: gemini-2.5-flash-lite
# GOOGLE_AI_MODEL=gemini-2.5-flash-lite

# Local AI Fallback flag — set to True to enable the /dl command
USE_LOCAL_AI=False

# Truth Social Monitor
# Chat ID of the Telegram group to send alerts to
TRUTH_ALERT_CHAT_ID=your_chat_id_here
# Optional: Override the RSS feed URL (defaults to https://trumpstruth.org/feed)
# TRUTH_RSS_URL=https://trumpstruth.org/feed
# OpenRouter API key — required for Persian translation of alerts
# Get one at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...
# Translation model via OpenRouter (default: Google Gemini 2.5 Flash)
# TRUTH_TRANSLATION_MODEL=google/gemini-2.5-flash

# ── Instagram Download Stack ──────────────────────────────────────────────────
# The bot tries methods in this order. Configure what fits your setup.
# Priority: Cobalt local → yt-dlp → Cobalt mirrors → instaloader → HikerAPI → gallery-dl

# PHASE 1 — Cobalt self-hosted (RECOMMENDED, cookie-free for public content)
# Deploy on your Oracle ARM server first:
#   docker run -d --name cobalt --restart unless-stopped \
#     -p 127.0.0.1:9000:9000 -e API_URL=http://localhost:9000 ghcr.io/imputnet/cobalt:10
# Then set:
# COBALT_LOCAL_URL=http://localhost:9000

# PHASE 2 — Instaloader session file (weeks-long lifetime vs hours for cookies)
# USE A DEDICATED DUMMY ACCOUNT — never your main Instagram account.
# Generate the session on the server (binds it to the server IP):
#   .venv/bin/instaloader --login your_dummy_username
# Then set:
# INSTALOADER_SESSION_USER=your_dummy_username
# Optional: explicit path (default: ~/.config/instaloader/session-{user})
# INSTALOADER_SESSION_FILE=/home/ubuntu/.config/instaloader/session-your_dummy_username

# PHASE 3 — HikerAPI paid fallback (~$0.001/request, residential proxies)
# https://hikerapi.com — used after instaloader, before gallery-dl
# HIKERAPI_KEY=your_hikerapi_key_here

# LEGACY — Cookie file rotation (still used as final fallback)
# Export full Netscape cookie files from Chrome/Firefox/Edge and upload to server.
# INSTAGRAM_COOKIES_FILES=cookies1.txt,cookies2.txt,cookies3.txt
# Single file fallback:
# INSTAGRAM_COOKIES_FILE=instagram_cookies.txt
# Session ID rotation (easiest but shortest lifetime):
# INSTAGRAM_SESSION_IDS=id1,id2,id3
# Or single session ID:
# INSTAGRAM_SESSION_ID=your_session_id_here

# Desktop-only — NOT for headless servers (Ubuntu ARM, Oracle Cloud, VPS)
# INSTAGRAM_COOKIES_FROM_BROWSER=chrome

# Legacy credentials — DO NOT USE (broken in current yt-dlp Instagram extractor)
# INSTAGRAM_USERNAME=your_instagram_username

# Admin chat ID for system alerts (cookie expiry, Cobalt status).
# Defaults to TRUTH_ALERT_CHAT_ID if not set. Get your ID via /chatid in the bot.
# ADMIN_CHAT_ID=your_admin_chat_id_here

# AI Result Cache — avoids redundant Groq/Gemini API calls for repeated posts
# Transcripts and translations are stored in a local SQLite file.
# Default: enabled. Set to false to disable.
# ENABLE_AI_CACHE=true

# How many days to keep cached results before expiry (default: 30 days)
# CACHE_TTL_DAYS=30

# Path to the SQLite cache file (default: ./ai_cache.db next to bot.py)
# CACHE_DB_PATH=./ai_cache.db
